# AI chat — public n8n webhook URL (browser POSTs here for streaming responses).
# No secrets: this is baked into the client bundle at build time.
# AI_CHAT_WEBHOOK_URL=https://n8n.example.com/webhook/texter-docs-chat

# RAG build sync (CI + local build only — never shipped to the browser).
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_...   # Supabase "secret key" (replaces legacy service_role).
# Either OPENAI_API_KEY (direct) OR EMBED_WEBHOOK_URL + EMBED_WEBHOOK_SECRET
# (route embeddings through the n8n "Texterdocs - Embeddings Proxy" workflow).
# OPENAI_API_KEY=
# EMBED_WEBHOOK_URL=https://n8n.texter.chat/webhook/texter-embed
# EMBED_WEBHOOK_SECRET=

# Giscus — copy this file to .env.local for local dev (IDs from giscus.app).
# GISCUS_REPO=whatsper/texterdocs
# GISCUS_REPO_ID=
# GISCUS_CATEGORY=Comments
# GISCUS_CATEGORY_ID=
# GISCUS_LANG=en
# (giscus iframe UI; default en. Hebrew header is in the site, not giscus.)

# Used by Templates JSON Import tool
# TEMPLATE_IMPORT_PROXY_URL=